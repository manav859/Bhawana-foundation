# ========================================
# Server Configuration
# ========================================
NODE_ENV=development
PORT=5000

# ========================================
# Database
# ========================================
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=bhawna-foundation

# ========================================
# Client
# ========================================
CLIENT_URLS=http://localhost:5174

# ========================================
# Authentication
# ========================================
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=1d
ADMIN_AUTH_MODE=mock

# ========================================
# File Uploads
# ========================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ========================================
# Rate Limiting
# ========================================
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=300

# ========================================
# SMTP / Email (placeholder for future)
# ========================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-email-password
# SMTP_FROM=noreply@bhawnafoundation.org

# ========================================
# Cloudinary (placeholder for future)
# ========================================
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ========================================
# Payment Gateway (placeholder for future)
# ========================================
# RAZORPAY_KEY_ID=your-key-id
# RAZORPAY_KEY_SECRET=your-key-secret