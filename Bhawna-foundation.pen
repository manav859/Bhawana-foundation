                  "id": "E3pjc",
                  "name": "pdoTitle",
                  "fill": "$text-dark",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Why We Fight for Education",
                  "fontFamily": "Poppins",
                  "fontSize": 32,
                  "fontWeight": "700"
                }
              ]
            },
            {
              "type": "frame",
              "id": "mS9g4",
              "name": "pdoRight",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "text",
                  "id": "BGIR8",
                  "name": "pdoDesc1",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "In many rural parts of India, poverty and lack of infrastructure force millions of children to drop out of school. Without proper education, they remain trapped in the cycle of poverty, vulnerable to exploitation and limited opportunities.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "Ovzk4",
                  "name": "pdoDesc2",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Our \"Education for All\" program addresses these systemic barriers. We don't just build schools; we create comprehensive support systems that provide scholarships, learning materials, capable teachers, and nutritional support to keep children in classrooms where they belong.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                }
              ]
            }
          ]
