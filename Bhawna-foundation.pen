                    {
                      "type": "text",
                      "id": "75gNO",
                      "name": "pd2AbDesc1",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "In the devastating monsoon floods of 2023, the only primary school serving three villages in the Sirohi district was completely destroyed. Since then, over 300 children have been either walking 8 kilometers to the nearest town or, in many cases, dropping out entirely.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "Nzblt",
                      "name": "pd2AbDesc2",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "The School Reconstruction Project aims to rebuild this critical educational infrastructure, not just replacing what was lost, but upgrading it to be flood-resistant, digitally equipped, and inclusive for all students.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
