                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "What started as a small initiative in Jaipur has now grown into a movement touching the lives of over 50,000 people across 25 cities in India. Our dedicated team of volunteers and professionals work tirelessly to bring positive change.",
                  "lineHeight": 1.7,
                  "fontFamily": "Inter",
                  "fontSize": 15,
                  "fontWeight": "normal"
